<script>
    const dots = document.querySelectorAll('.partner_dots .dot');
    const carousel = document.querySelector('.carousel_container_partners');

    dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
            if (!carousel) return;
            const carouselItem = carousel.children[index];
            if (!carouselItem) return;
            carouselItem.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' }); 
           
            dots.forEach(d => d.classList.remove('active'));
            dot.classList.add('active');
        });
    });

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                if (!carousel) return;
                const index = Array.from(carousel.children).indexOf(entry.target);
                dots.forEach(d => d.classList.remove('active'));
                if (dots[index]) {
                    dots[index].classList.add('active');
                }
            }
        });
    }, { threshold: 0.5});

    document.querySelectorAll('.partnergrid-mobile').forEach(item => {
        observer.observe(item);
    });

</script>

