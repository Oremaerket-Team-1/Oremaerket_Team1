---
import { Image } from "astro:assets";
import hero from "../Image/heroimage.webp";
---

<Image src={hero} alt="solnedgang i naturen med overlays af mennesker der handler" class="heroimg"/>


<style>
.heroimg {
  height: 500px;
  width: 100%;
    object-fit: cover;
  display: block;
  border-radius: 0 0 20px 20px;
  margin-bottom: var(--XL-);
}

@media (min-width: 800px) {
  .heroimg {
  
    margin-bottom: var(--XXL-);
  }
}

 

</style>
