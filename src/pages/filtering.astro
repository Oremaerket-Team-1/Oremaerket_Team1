</Layout>

<style>

  section{
       margin-top: var(--M-);
        margin: 0 var(--S-);
  }
p {
  margin-bottom: var(--S-);
}

h2 {
  max-width: 300px;
}

.seestroke {
  display: flex;
  align-items: center;
justify-content: center;
margin-bottom: var(--S-);
}

.seemore {
display: flex;
align-items: center;
justify-content: center;
margin-bottom: 0.5rem;
}

  .card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--L-);
    margin-bottom: var(--S-);
  }

.places {
  display: flex;
  flex-wrap: wrap;
  gap: var(--XS-);
  justify-content: center;
}
    .buttons {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
          gap: var(--XS-);
  margin-top: var(--XS-);
  margin-bottom: var(--S-);
    }
    .button-svg {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        border: none;
    }

    .button-label {
        position: absolute;
        font-weight: bold;
        cursor: pointer;
    }

.button-svg:hover rect{
    fill: var(--dankort-sort);
}

.button-svg:focus rect{
    fill: var(--dankort-sort);
    color: var(--dankort-hvid);
}

.button-svg:hover .button-label {
     color: var(--dankort-hvid);
}

.button-svg:focus .button-label {
  color: var(--dankort-hvid);
}


  @media (min-width: 800px) {

    section {
      margin: 0 120px;
    }

     .buttons {
    flex-direction: row;
    align-items: start;
    justify-content: start;
    margin-bottom: var(--M-);
      white-space: nowrap;
  }

  h2 {
  max-width: 100%;
}

  .card {
 grid-template-columns: repeat(3, 1fr);
 grid-template-rows: auto;

  }
  }
  
</style>

<script>

    document.querySelectorAll("#filter button").forEach((button) => button.addEventListener("click", filtrer));

    // @ts-ignore
    function filtrer(e) {
        const cards = document.querySelectorAll("article");
        const valgtype = e.currentTarget.dataset.type;
        cards.forEach((card) => { console.log("card.dataset.type:", card.dataset.type);
          if (card.dataset.type == valgtype || valgtype == "Alle") {
            card.classList.remove("hide");

            } else { 
              card.classList.add("hide");
            }
    });
  }
</script>