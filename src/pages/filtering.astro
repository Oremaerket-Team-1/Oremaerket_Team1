  display: flex;
  align-items: center;
justify-content: center;
margin-bottom: var(--S-);
}

.seemore {
display: flex;
align-items: center;
justify-content: center;
margin-bottom: 0.5rem;
}

  .card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--L-);
    margin-bottom: var(--S-);
  }
.buttons {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--XS-);
