---
//@ts-nocheck
import '@fontsource-variable/raleway/wght.css';
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1"  />
  <meta name="robots" content="noindex">
    <link rel="icon" type="image/png" sizes="48X55" href="/assets/img/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>Øremærket</title>
  </head>
    <body>
  <Header />
    <main>
      <slot />
    </main>
  <Footer />
    </body>
</html>

<style is:global>
  /*-------------------- RESET ----------------------- */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

::selection {
  background-color: var(--dankort-sort);
  color: var(--dankort-hvid);
}

body {
  background-color: var(--bg-base);
  font-family: "Raleway Variable", sans-serif;
}

main {
  max-width: 1440px;
  margin: 0 auto;
}

/*-------------------- VARIABLER ----------------------- */

/*-------------------- FARVER ----------------------- */
html {
  --bg-base: #f5f5f5;
  --dankort-roed: #e21f22;
  --dankort-gul: #ffd998;
  --dankort-gul-var1: #ffe8b6;
  --dankort-groen: #81d979;
  --dankort-groen-var1: #a1eaac;
  --dankort-blaa: #3ab8ea;
  --dankort-blaa-var1: #90d9f8;
  --dankort-blaa-faq: #304959;
  --dankort-sort: #1e1e1e;
  --dankort-hvid: #ffffff;
  --dankort_graa_var1: #6a6a6a;
  --dankort_graa_var2: #b4b4b4;
  --dankort_graa_var3: #d9d9d9;
}

/*-------------------- FONTE ----------------------- */

.h1 {
  color: var(--dankort-sort);
  font-size: 24px;
  font-style: normal;
  font-weight: 800;
  line-height: normal;
  margin-bottom: var(--S-);
}

.h2 {
  color: var(--dankort-sort);
  font-size: 20px;
  font-style: normal;
  font-weight: 700;
  line-height: normal;
  margin-bottom: var(--S-);
}

.h3 {
  color: var(--dankort-sort);
  font-size: 18px;
  font-style: normal;
  font-weight: 600;
  line-height: normal;
  margin-bottom: var(--S-);
}

.h4 {
  color: var(--dankort-sort);
  font-size: 14px;
  font-style: normal;
  font-weight: 600;
  line-height: normal;
  margin-bottom: var(--S-);
}

.p {
  color: var(--dankort-sort);
  font-size: 14px;
  font-style: normal;
  font-weight: 500;
  line-height: var(--S-);
  max-width: 65ch;
}

@media (min-width: 800px) {
  .h1 {
    font-size: 46px;
  }
  .h2 {
    font-size: 40px;
  }
  .h3 {
    font-size: 36px;
  }
  .h4 {
    font-size: 20px;
  }
  .p {
    font-size: 16px;
    line-height: 30px;
  }
}

/*-------------------- SPACING ----------------------- */

html {
  --XXS-: 5px;
  --XS-: 10px;
  --S-: 20px;
  --M-: 30px;
  --L-: 40px;
  --XL-: 80px;
  --XXL-: 120px;
}

</style>
