  /* SLIDESHOW CSS */

  .slideshow {
    position: relative;
    width: 100%;
    height: 400px;
    overflow: hidden;
    border-radius: var(--S-);
    margin-bottom: var(--S-);
  }

  .slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    animation: fade 12s infinite;
  }

  /* animation timing */
  .slide:nth-child(1) {
    animation-delay: 0s;
  }

  .slide:nth-child(2) {
    animation-delay: 4s;
  }

  .slide:nth-child(3) {
    animation-delay: 8s;
  }

  @keyframes fade {
    0% {
      opacity: 0;
    }

    8% {
      opacity: 1;
    }

    30% {
      opacity: 1;
    }

    38% {
      opacity: 0;
    }

    100% {
      opacity: 0;
    }
  }

  @media (min-width: 800px) {
    .section1 {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }
