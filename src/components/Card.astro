---
const { Dankort } = Astro.props;
---

<article><h2 class="h2">{Dankort.place}</h2>
    <img src={Dankort.image} alt="naturområderne i Danmark">
    <a href={Dankort.link}>
    <button>LÆS MERE</button>
    </a>
    
</article>

<style>
    article{
        padding: 2rem;
    }
    img {
        border-radius: 20px;
        max-height: 320px;
        max-width: 320px;
    }
</style>