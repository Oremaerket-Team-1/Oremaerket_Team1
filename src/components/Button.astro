---
const {title} = Astro.props;
---

<button><p>{title}</p></button>

<style>
button {
  width: 184px;
  height: 59px;
  font-weight: bold; 
  border-radius: 20px;
  color: var(--dankort-hvid);
  background: var(--dankort-roed);
  border: none;
  cursor: pointer;
}

button:hover {
  background-color:#BD191C;
}
</style>