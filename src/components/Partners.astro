<style>

.mobile {
    display: block;
    margin-bottom: var(--XL-);
}

.desktop {
    display: none;
}
 
.partnerbox {
    height: 180px;
    width: auto;
    display: flex;
    justify-content: center;
    padding: 35px;
    background-color: var(--dankort-hvid);
    border-radius: 20px;
    border: 1px solid var(--dankort-sort);
    

    img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
          
    }

    
}

.partnergrid-mobile {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 1rem;
    width: 100%;
    flex: 0 0 100%;
    scroll-snap-align: center;
 
}

section {
    margin: var(--S-);

}

.carousel_container {
 display: flex;
        flex-flow: row nowrap;
        width: 100%;
        overflow-x: auto;
        gap: 2rem;
        scroll-snap-type: x mandatory;
}

 .carousel_container::-webkit-scrollbar { 
        display: none;
    }


    @media (min-width: 800px){

    
       
        .mobile {
            display: none;
        }

        .desktop {
            display: block;
            margin: 0 var(--XXL-);
            margin-bottom: var(--XXL-);
        }

        .partnergrid-desktop {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            width: 100%;
            
        }

        .partnerbox {
             padding: 20px;
        }

    }

     @media (min-width: 1080px){
         .partnergrid-desktop {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 2rem;
            width: 100%;
            
        }
        
        .partnerbox {
         padding: 40px;
        }
        
     }



</style>